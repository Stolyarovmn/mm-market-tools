# ── Secrets & credentials ─────────────────────────────────────────────────────
.env
*.env
*.token
secrets/
credentials/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── Large data files (use LFS or keep local) ──────────────────────────────────
data/bundles/
data/cache/
data/raw/
data/reports/*.csv
data/reports/*.xlsx
data/reports/*.zip
# Keep: JSON dashboards (small), reviews, config
!data/dashboard/
!data/reviews/
!data/reply_config.json
data/local/*
!data/local/README.md

# ── Job runs (temp logs) ──────────────────────────────────────────────────────
job_runs/
*.log

# ── OS / editors ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# ── Node (if any) ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Cowork session artifacts (do NOT track) ───────────────────────────────────
*.session
.claude/
